<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All users</title>
    <style>
        table,
        th,
        td {
            border: 1px solid blue;
        }
    </style>
</head>

<body>
    <table>
        <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Username</th>

        </tr>


        <% for(user of users){ %>
            <tr>
                <td>
                    <%= user.id %>
                </td>
                <td>
                    <%= user.email %>
                </td>
                <td>
                    <%= user.username %>
                </td>
                <td>
                    <form action="/user/<%= user.id %>/edit" method="GET">
                        <button>
                            EDIT USERNAME
                        </button>
                    </form>
                </td>
            </tr>
            <% } %>
    </table>
</body>

</html>